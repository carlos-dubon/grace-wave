---
import Layout from "@/layouts/Layout.astro";
import HeroBackground from "@/components/HeroBackground.astro";
import { Header } from "@/components/ui/header";
import { VerseOfTheDay } from "@/components/ui/verse-of-the-day";
import { Card } from "@/components/ui/card";
import { Player } from "@/components/ui/player";
import { LiveChat } from "@/components/ui/live-chat";
---

<Layout>
    <HeroBackground />
    <Header client:load />

    <div class="relative z-20 pt-17">
        <div
            class="w-full max-w-7xl mx-auto px-4 lg:px-8 flex flex-col justify-center gap-16"
        >
            <div
                class="grid sm:grid-cols-2 items-center gap-12 pt-16 min-h-[75dvh]"
            >
                <div class="flex flex-col gap-4">
                    <div class="flex items-center gap-3">
                        <span class="relative flex h-3 w-3">
                            <span
                                class="absolute inline-flex h-full w-full animate-ping rounded-full bg-red-500 opacity-75"
                            ></span>
                            <span
                                class="relative inline-flex h-3 w-3 rounded-full bg-red-500"
                            ></span>
                        </span>
                        <span
                            class="text-sm font-semibold uppercase tracking-widest text-red-500"
                        >
                            Live Now
                        </span>
                    </div>
                    <h1
                        class="font-space-grotesk text-5xl font-bold leading-tight tracking-tight text-foreground md:text-7xl"
                    >
                        <span class="text-balance"
                            >Faith On The{" "}<span class="text-accent"
                                >Airwaves</span
                            ></span
                        >
                    </h1>
                    <p
                        class="max-w-lg text-lg leading-relaxed text-muted-foreground"
                    >
                        Tune in to Grace Wave Radio for uplifting worship music,
                        inspiring messages, and a faith community that grows
                        together. Chat with the host live and share your prayer
                        requests.
                    </p>
                    <Player client:load />
                </div>
                <div class="flex-col flex gap-6">
                    <VerseOfTheDay client:load />
                    <div class="grid grid-cols-2 gap-4">
                        <Card className="gap-1">
                            <span
                                class="font-mono text-2xl font-bold text-accent"
                                >24/7</span
                            >
                            <span class="text-xs text-muted-foreground">
                                Always Broadcasting
                            </span>
                        </Card>
                        <Card className="gap-1">
                            <span
                                class="font-mono text-2xl font-bold text-accent"
                                >12K+</span
                            >
                            <span class="text-xs text-muted-foreground">
                                Faithful Listeners
                            </span>
                        </Card>
                    </div>
                </div>
            </div>
            <div class="flex flex-col gap-12">
                <div class="flex flex-col gap-3">
                    <h2
                        class="font-space-grotesk text-3xl font-bold text-foreground md:text-4xl"
                    >
                        <span class="text-balance"
                            >Chat With The <span class="text-accent">Host</span
                            ></span
                        >
                    </h2>
                    <p class="max-w-xl text-muted-foreground">
                        Join the live conversation. Share prayer requests,
                        request worship songs, and fellowship with other
                        listeners in real time.
                    </p>
                </div>
                <LiveChat client:load />
            </div>
        </div>
    </div>
</Layout>
